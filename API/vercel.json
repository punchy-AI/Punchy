{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/searchUnified",
      "dest": "/api/searchUnified.js"
    },
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/api/translate",
      "dest": "/api/translate.js"
    }
    // ✅ PLUS DE ROUTE /api/chart
  ]
}
